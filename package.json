{
  "name": "yummies",
  "version": "7.15.2",
  "scripts": {
    "prepare": "pnpm dev:install-hooks",
    "clean": "rm -rf dist",
    "lint:check": "pnpm exec biome check --write --no-errors-on-unmatched --files-ignore-unknown=true",
    "ts:check": "tsc --noEmit",
    "check": "npm run lint:check && npm run ts:check",
    "prebuild": "npm run clean && npm run check",
    "build:watch": "pnpm build && nodemon --watch src --ext ts --exec \"pnpm build\"",
    "build": "vite build",
    "pub": "pnpm build && sborshik publish --useDistDir",
    "pub:patch": "PUBLISH_VERSION=patch pnpm pub",
    "pub:minor": "PUBLISH_VERSION=minor pnpm pub",
    "pub:major": "PUBLISH_VERSION=major pnpm pub",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest watch --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "dev": "pnpm test:watch",
    "dev:install-hooks": "if [ -z \"$CI\" ]; then lefthook install; fi",
    "docs": "pnpm build && cd docs && pnpm dev",
    "docs:install": "cd docs && pnpm i",
    "docs:build": "cd docs && pnpm build",
    "docs:serve": "cd docs && pnpm preview",
    "docs:generate": "node --experimental-strip-types scripts/generate-api-docs.ts"
  },
  "keywords": [
    "javascript",
    "typescript",
    "utilities"
  ],
  "author": "js2me",
  "license": "MIT",
  "description": "Frontend utilities for JavaScript projects with open source code",
  "bugs": {
    "url": "https://github.com/js2me/yummies/issues"
  },
  "homepage": "https://js2me.github.io/yummies/api/async/",
  "repository": {
    "type": "git",
    "url": "git://github.com/js2me/yummies"
  },
  "peerDependencies": {
    "mobx": "^6.12.4",
    "react": "^18 || ^19"
  },
  "peerDependenciesMeta": {
    "mobx": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "sideEffects": false,
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "dompurify": "^3.3.3",
    "nanoid": "^5.1.7",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.2",
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.30.0",
    "@types/node": "^20.19.37",
    "@types/react": "^18.3.28",
    "@vitest/coverage-istanbul": "^4.1.2",
    "commitfmt": "^1.0.4",
    "js2me-biome-config": "^1.1.0",
    "jsdom": "^29.0.1",
    "lefthook": "^1.13.6",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "sborshik": "^3.0.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@9.5.0+sha512.140036830124618d624a2187b50d04289d5a087f326c9edfc0ccd733d76c4f52c3a313d4fc148794a2a9d81553016004e6742e8cf850670268a7387fc220c903",
  "type": "module"
}